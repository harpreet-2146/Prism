# ================================================================
# PRISM BACKEND - ENVIRONMENT VARIABLES
# ================================================================
# Copy this file to .env and fill in your actual values.
# NEVER commit your .env file to git.
# ================================================================

# ================================================================
# APPLICATION (required)
# ================================================================
NODE_ENV=development
PORT=5000
FRONTEND_URL=http://localhost:5173
# Full URL of this backend (used in export/download links)
BASE_URL=http://localhost:5000

# ================================================================
# DATABASE (required)
# ================================================================
# Local PostgreSQL:
DATABASE_URL=postgresql://postgres:your_password_here@localhost:5432/prism_db

# Railway production example:
# DATABASE_URL=postgresql://postgres:XXXXX@containers-us-west-XX.railway.app:5432/railway

# ================================================================
# SECURITY - JWT (required)
# ================================================================
# Generate with:
# node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=REPLACE_WITH_64_BYTE_HEX
JWT_REFRESH_SECRET=REPLACE_WITH_DIFFERENT_64_BYTE_HEX
JWT_ACCESS_EXPIRES_IN=1h
JWT_REFRESH_EXPIRES_IN=30d

# ================================================================
# RATE LIMITING
# ================================================================
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ================================================================
# GROQ AI - LLM (required for chat)
# ================================================================
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_MAX_TOKENS=9000
GROQ_TEMPERATURE=0.3
GROQ_CONTINUATION_MAX_TOKENS=6000
ARTICLE_MIN_STEPS=16
ARTICLE_MIN_WORDS=2800

# ================================================================
# HUGGINGFACE - Embeddings (required for document search)
# ================================================================
HF_TOKEN=your_huggingface_token_here
HF_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# ================================================================
# OCR.SPACE API - Image Text Extraction (required)
# ================================================================
OCR_SPACE_API_KEY=your_ocr_space_api_key_here
OCR_SPACE_ENGINE=2
OCR_SPACE_LANGUAGE=eng

# ================================================================
# TAVILY AI - Web Search (optional but recommended)
# ================================================================
TAVILY_API_KEY=your_tavily_api_key_here
TAVILY_SEARCH_DEPTH=advanced
TAVILY_MAX_RESULTS=3

# ================================================================
# AI IMAGE GENERATION (optional)
# ================================================================
ENABLE_AI_IMAGE_GENERATION=false
HF_IMAGE_MODEL=stabilityai/stable-diffusion-2-1

# ================================================================
# IMAGE FALLBACKS (optional)
# ================================================================
UNSPLASH_ACCESS_KEY=your_unsplash_access_key
PEXELS_API_KEY=your_pexels_api_key

# ================================================================
# FILE UPLOADS
# ================================================================
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=50
ALLOWED_MIME_TYPES=application/pdf
MAX_PAGES_TO_EXTRACT=500
PDF_IMAGE_SCALE=1.5
PDF_IMAGE_QUALITY=85

# ================================================================
# PYTHON MICROSERVICE (optional)
# ================================================================
PYTHON_SERVICE_URL=http://localhost:8000
PYTHON_SERVICE_API_KEY=
PYTHON_SERVICE_TIMEOUT=60000

# ================================================================
# PDF EXPORT (Puppeteer)
# ================================================================
EXPORT_TEMP_DIR=./exports
EXPORT_TIMEOUT_MS=30000
EXPORT_MAX_CONCURRENT=3

# ================================================================
# CLOUDINARY (optional, if used in your setup)
# ================================================================
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# ================================================================
# LOGGING
# ================================================================
LOG_LEVEL=info
